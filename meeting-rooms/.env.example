# Supabase — get these from https://supabase.com/dashboard
# Project Settings -> API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# OPTIONAL — Legacy JWT-format anon key (eyJ...).
# Required ONLY for resumable uploads of large files (> 50 MB) in
# the meeting-summary feature. Supabase's TUS endpoint won't accept
# the new "publishable" keys; it requires JWT format.
# Find it in Supabase Dashboard -> Settings -> API -> "Legacy JWT
# keys" (still available alongside new publishable keys).
# Files <= 50 MB upload fine without this.
VITE_SUPABASE_LEGACY_JWT=
